{
  "name": "multi-system-funbox-emulator",
  "version": "1.1.0",
  "description": "A modern glassmorphic multi-system retro emulator dashboard (PSX, N64, SNES, GBA) using EmulatorJS, Vite, and TypeScript.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx src/server/server.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "author": "Antigravity",
  "license": "ISC"
}
